	(text "When switch is in position 3, \nR4 || R5 limits current sinking to about 12mA,\nwhich will show if the transistor is weak."
		(exclude_from_sim no)
		(at 182.118 105.664 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify right)
		)
		(uuid "6b0f2f0a-6357-4b3d-a46e-0e15fb5e605b")
	)
	(text "When switch is open or position 1,\nR4 limits current sinking to about 2mA, \nwhich is a realistic load for a single logic input."
		(exclude_from_sim no)
		(at 210.312 106.172 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "7255be8e-1459-402c-a09d-842cb112f0d2")
	)
	(text "LED lights when ground (logic 0?)\nis asserted by either the switch \nor the module."
		(exclude_from_sim no)
		(at 60.96 71.882 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify right)
		)
		(uuid "858b0652-294f-4735-b92b-16ac3fb1e775")
	)
	(text "Switch position 1 emulates a PNP output transistor turned on.\nSwitch open emulates an input pulled down to -12V (via R4 and D2).\nSwitch position 3 emulates the load of many inputs on e.g. a bus driver output."
		(exclude_from_sim no)
		(at 181.864 85.852 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify right)
		)
		(uuid "8731ec92-0076-4324-82c7-aad086773656")
	)
	(text "LED lights when ground is asserted by \neither the switch or the module.\nWhen switch is in position 3, LED will be \nbrighter if module transistor is good."
		(exclude_from_sim no)
		(at 210.312 118.872 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "a05fa6ac-a735-468a-a5f0-018d746e119f")
	)
	(text "Switch emulates a PNP output transistor,\nso the pin is driven with high current\njust like in a real circuit."
		(exclude_from_sim no)
		(at 61.468 35.56 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify right)
		)
		(uuid "b30e851e-4b64-4771-9a55-c979d92684ab")
	)
	(text "R2 limits current sinking ability\nto about 2mA, which is a realistic \nload and reasonable for the LED."
		(exclude_from_sim no)
		(at 61.468 59.436 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify right)
		)
		(uuid "cfcb7c62-c1c1-4102-ab3d-097019440fa4")
	)
	(text "R3 limits fault current to shorted pins\nto 25mA (no hard short to GND)"
		(exclude_from_sim no)
		(at 181.61 75.184 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify right)
		)
		(uuid "ecbcf3d3-58d0-4f34-8580-0e7c3cf4389e")
	)
	(text "R1 limits fault current to shorted pins\n(no hard short to GND)"
